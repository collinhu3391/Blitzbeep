function checkAnswer(u, c) {
 const n = s => s.toLowerCase().replace(/\(.*?\)/g,'').replace(/[^a-z0-9\s]/g,'').replace(/\s+/g,' ').trim();
 const un = n(u), cn = n(c);
 if (un === cn) return true;
 if (cn.includes(un) || un.includes(cn)) return true;
 const cw = cn.split(' ').filter(w=>w.length>3), uw = un.split(' ').filter(w=>w.length>3);
 const m = uw.filter(w=>cw.some(cw=>cw.includes(w)||w.includes(cw)));
 return m.length > 0 && m.length >= Math.min(uw.length,cw.length)*0.5;
}

