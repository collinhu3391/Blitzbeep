function runSearch() {
 const raw = document.getElementById('searchInput').value.trim();
 const filter = document.getElementById('searchFilter').value;
 // Gather active category filters from toggle buttons
 const checkedCats = ['srcBtnLit','srcBtnArt','srcBtnHist','srcBtnBio','srcBtnPhys','srcBtnComp','srcBtnCurr']
.map(id => document.getElementById(id))
.filter(el => el && el.classList.contains('active'))
.map(el => el.dataset.cat);
 const container = document.getElementById('searchResults');
 const countEl = document.getElementById('searchCountNum');

 // Need either a search term OR at least one category active to show results
 const hasQuery = raw.trim().length >= 1;
 const hasCatFilter = checkedCats.length > 0;
 const hasSetFilter = filter !== 'all';

 if (!hasQuery && !hasCatFilter && !hasSetFilter) {
 countEl.textContent = '—';
 container.innerHTML = '<div class="search-empty"><span class="search-empty-icon">🔍</span>Type a buzzword to search<br>across all 3,400+ questions</div>';
 return;
 }

 // Parse quoted phrases and bare terms
 // e.g. "battle of" napoleon → exactPhrases=["battle of"], bareTerms=["napoleon"]
 const exactPhrases = [];
 const bareTerms = [];
 let parseStr = raw;
 const quoteRe = /"([^"]+)"/g;
 let qm;
 while ((qm = quoteRe.exec(raw)) !== null) {
 exactPhrases.push(qm[1].toLowerCase());
 }
 parseStr = raw.replace(/"[^"]*"/g, '').trim();
 if (parseStr) bareTerms.push(...parseStr.toLowerCase().split(/\s+/).filter(Boolean));

 const index = buildSearchIndex();

 const typeFilter = document.getElementById('searchTypeFilter')?.value || 'all';
 const results = index.filter(item => {
 if (typeFilter !== 'all' && item.type !== typeFilter) return false;
 // Filter by set
 if (filter !== 'all') {
 if (!item.packet.includes(filter)) return false;
 }
 // Filter by category (if any boxes checked, item must match one)
 if (checkedCats.length > 0) {
 let itemCat;
 if (item.type === 'bonus') {
 itemCat = classifyQuestion((item.leadin||'') + ' ' + item.question + ' ' + item.answer, '');
 } else {
 itemCat = getQuestionCategory(item.packetIdx, item.questionIdx);
 }
 if (!checkedCats.includes(itemCat)) return false;
 }
 // Exact quoted phrases must appear as substrings (only if any specified)
 if (exactPhrases.length > 0 && !exactPhrases.every(p => item._ql.includes(p) || item._al.includes(p))) return false;
 // Bare terms must also appear (only if any specified)
 if (bareTerms.length > 0 && !bareTerms.every(t => item._ql.includes(t) || item._al.includes(t))) return false;
 return true;
 });

 countEl.textContent = results.length;

 if (results.length === 0) {
 container.innerHTML = '<div class="search-empty"><span class="search-empty-icon">🤷</span>No questions found<br>for "' + escapeHtml(raw) + '"</div>';
 return;
 }

 // Render up to 200 results
 const show = results.slice(0, hasQuery? 200 : 100);
 container.innerHTML = show.map(r => {
 const isBonus = r.type === 'bonus';
 const cat = isBonus
? classifyQuestion((r.leadin||'') + ' ' + r.question + ' ' + r.answer, '')
 : getQuestionCategory(r.packetIdx, r.questionIdx);
 const catClass = CAT_BADGE_CLASS[cat] || 'cat-badge-hist';
 const catLabel = CAT_LABELS[cat] || cat;

 let qHtml = escapeHtml(r.question);
 let lHtml = isBonus? escapeHtml(r.leadin || '') : '';
 [...exactPhrases,...bareTerms].forEach(t => {
 const re2 = new RegExp('(' + escapeRegex(t) + ')', 'gi');
 qHtml = qHtml.replace(re2, '<mark>$1</mark>');
 if (isBonus) lHtml = lHtml.replace(re2, '<mark>$1</mark>');
 });

 if (isBonus) {
 const partLetter = String.fromCharCode(65 + (r.partIdx || 0));
 return `<div class="search-result-card">
 <div class="src-meta">
 <span class="src-packet">${escapeHtml(r.packet)}</span>
 <span class="src-bonus-tag">BONUS ${partLetter}</span>
 <span class="cat-badge ${catClass}">${catLabel}</span>
 <span class="src-answer">${escapeHtml(r.answer)}</span>
 </div>
 ${lHtml? `<div class="src-leadin">${lHtml}</div>` : ''}
 <div class="src-body">${qHtml}</div>
 <button class="src-goto" onclick="goToBonus(${r.bonusIdx})">→ Practice this bonus</button>
 </div>`;
 }

 return `<div class="search-result-card">
 <div class="src-meta">
 <span class="src-packet">${escapeHtml(r.packet)} · Q${r.questionIdx + 1}</span>
 ${r.powerIdx != null? '<span class="src-power-badge">⚡ Power</span>' : ''}
 <span class="cat-badge ${catClass}">${catLabel}</span>
 <span class="src-answer">${escapeHtml(r.answer)}</span>
 </div>
 <div class="src-body">${qHtml}</div>
 <button class="src-goto" onclick="goToQuestion(${r.packetIdx}, ${r.questionIdx})">→ Practice this question</button>
 </div>`;
 }).join('');
 if (results.length > 200) {
 container.innerHTML += '<div class="search-empty" style="padding:20px">Showing 200 of ' + results.length + ' results — narrow your search</div>';
 }
}


