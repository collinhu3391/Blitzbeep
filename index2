 card.classList.remove('power-flash');
 void card.offsetWidth;
 card.classList.add('power-flash');
 setTimeout(() => card.classList.remove('power-flash'), 600);

 // Confetti particles — bigger burst for power buzz
 const COLORS = ['#FFD700','#FF6B6B','#4ECDC4','#45B7D1','#96CEB4','#FFEAA7','#DDA0DD','#FF8C69'];
 const particles = [];
 const count = isPower? 160 : 60;

 for (let i = 0; i < count; i++) {
 particles.push({
 x: Math.random() * canvas.width,
 y: -10 - Math.random() * 100,
 w: 8 + Math.random() * 10,
 h: 4 + Math.random() * 6,
 color: COLORS,
 rot: Math.random() * Math.PI * 2,
 vx: (Math.random() - 0.5) * 4,
 vy: 2 + Math.random() * 4,
 vrot: (Math.random() - 0.5) * 0.15,
 alpha: 1,
 });
 }

 let frame = 0;
 const maxFrames = 120;

 function drawFrame() {
 ctx.clearRect(0, 0, canvas.width, canvas.height);
 particles.forEach(p => {
 p.x += p.vx;
 p.y += p.vy;
 p.vy += 0.08; // gravity
 p.rot += p.vrot;
 if (frame > maxFrames * 0.6) p.alpha -= 0.03;
 ctx.save();
 ctx.translate(p.x, p.y);
 ctx.rotate(p.rot);
 ctx.globalAlpha = Math.max(0, p.alpha);
 ctx.fillStyle = p.color;
 ctx.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);
 ctx.restore();
 });
 frame++;
 if (frame < maxFrames) requestAnimationFrame(drawFrame);
 else ctx.clearRect(0, 0, canvas.width, canvas.height);
 }

 requestAnimationFrame(drawFrame);
}

