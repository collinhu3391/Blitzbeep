// Chrome loads voices asynchronously — retry until available
function loadVoices() {
 const v = window.speechSynthesis.getVoices();
 if (!v.length) return; // not ready yet — onvoiceschanged will fire again
 const pref = [
 'Google US English','Google UK English Female',
 'Samantha','Karen','Daniel','Alex',
 'Microsoft Aria Online','Microsoft Jenny Online',
 'Microsoft Zira Desktop','Microsoft David Desktop'
 ];
 for (const n of pref) {
 const found = v.find(x => x.name === n);
 if (found) { ttsVoice = found; return; }
 }
 ttsVoice = v.find(x => x.lang === 'en-US') ||
 v.find(x => x.lang.startsWith('en')) ||
 v[0] || null;
}

function toggleTTS() {
 ttsEnabled = !ttsEnabled;
 const btn = document.getElementById('btnTTS');
 if (ttsEnabled) {
 // Force voice load on first user gesture (required by Chrome)
 loadVoices();
 btn.textContent = '🔊 TTS ON';
 btn.style.borderColor = 'rgba(192,0,26,0.5)';
 btn.style.color = 'var(--accent)';
 } else {
 btn.textContent = '🔇 TTS OFF';
 btn.style.borderColor = btn.style.color = '';
 stopTTS();
 }
}

function stopTTS() {
 if (window.speechSynthesis) window.speechSynthesis.cancel();
}

// Chrome has a bug where speechSynthesis pauses after ~15s if the tab loses focus.
// Keep it alive with a silent periodic ping while speaking.
let _ttsPingTimer = null;
function _startTTSPing() {
 _stopTTSPing();
 _ttsPingTimer = setInterval(() => {
 if (!ttsEnabled || !window.speechSynthesis) return;
 if (window.speechSynthesis.speaking) {
 window.speechSynthesis.pause();
 window.speechSynthesis.resume();
 }
 }, 10000);
}
function _stopTTSPing() {
 if (_ttsPingTimer) { clearInterval(_ttsPingTimer); _ttsPingTimer = null; }
}

function speakQuestion() {
 if (!ttsEnabled || !window.speechSynthesis) return;
 stopTTS();

 const q = ALL_PACKETS[currentPacket].questions[currentQuestion];
 const text = q.question;

 // Chrome requires voices to be loaded before speaking.
 // If not loaded yet, wait briefly then retry once.
 const doSpeak = () => {
 const u = new SpeechSynthesisUtterance(text);
 // Re-pick voice each time (Chrome can lose the reference)
 const voices = window.speechSynthesis.getVoices();
 if (voices.length) {
 const pref = ['Google US English','Google UK English Female','Samantha','Karen','Daniel','Alex'];
 const picked = pref.map(n => voices.find(v => v.name === n)).find(Boolean) ||
 voices.find(v => v.lang === 'en-US') ||
 voices.find(v => v.lang.startsWith('en')) ||
 voices[0];
 if (picked) u.voice = picked;
 }
 u.lang = 'en-US';
 u.rate = Math.min(1.8, Math.max(0.5, readSpeed / 160));
 u.pitch = 1;
 u.volume = 1;
 u.onstart = () => _startTTSPing();
 u.onend = () => _stopTTSPing();
 u.onerror = () => _stopTTSPing();
 window.speechSynthesis.speak(u);
 };

 if (window.speechSynthesis.getVoices().length) {
 doSpeak();
 } else {
 // Voices not ready — wait for them then speak
 const handler = () => {
 window.speechSynthesis.removeEventListener('voiceschanged', handler);
 doSpeak();
 };
 window.speechSynthesis.addEventListener('voiceschanged', handler);
 // Fallback: try anyway after 300ms in case event doesn't fire
 setTimeout(() => {
 if (window.speechSynthesis.pending || window.speechSynthesis.speaking) return;
 doSpeak();
 }, 300);
 }
}

// ═══════════════════════════════════════════════
// ONLINE MULTIPLAYER
// Uses wss://ws.ifelse.io — free public WebSocket
// relay. Messages are JSON tagged with roomCode so
// only players in the same room see each other.
// ═══════════════════════════════════════════════
const WS_RELAY = 'wss://ws.ifelse.io';

function genCode() {
 const c = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
 return Array.from({length:5}, ()=>c[Math.floor(Math.random()*c.length)]).join('');
}

function wsSend(data) {
 if (!ws || ws.readyState !== WebSocket.OPEN) return;
 ws.send(JSON.stringify({...data, room: roomCode, from: playerName }));
}

function wsConnect(onReady) {
 if (ws) { try { ws.onclose=null; ws.close(); } catch(e){} ws=null; }
 ws = new WebSocket(WS_RELAY);

 ws.onopen = () => {
 setConnStatus('connected');
 onReady && onReady();
 };

 ws.onmessage = (e) => {
 let msg; try { msg = JSON.parse(e.data); } catch { return; }
 if (msg.room !== roomCode) return; // different room, ignore
 if (msg.from === playerName) return; // own echo, ignore
 onMsg(msg);
 };

 ws.onclose = () => {
 setConnStatus('disconnected');
 if (roomCode) setTimeout(() => wsConnect(), 2500);
 };

 ws.onerror = () => setConnStatus('error');
}

function onMsg(msg) {
 switch (msg.type) {

 case 'join':
 players[msg.name] = players[msg.name] || { pts: 0 };
 toast(`${msg.name} joined`);
 renderOnlineScoreboard();
 // Host sends current state back to the new joiner
 if (isHost) wsSend({ type: 'state', packet: currentPacket, question: currentQuestion, players });
 break;

 case 'state':
 // Received from host — sync to their current position
 if (msg.players) players = msg.players;
 players[playerName] = players[playerName] || { pts: 0 };
 currentPacket = msg.packet;
 currentQuestion = msg.question;
 populatePacketSelect();
 populateQuestionSelect();
 loadQuestion(false);
 renderOnlineScoreboard();
 break;

 case 'navigate':
 currentPacket = msg.packet; currentQuestion = msg.question;
 populatePacketSelect(); populateQuestionSelect();
 loadQuestion(false);
 break;

 case 'buzz':
 if (!buzzQueue.includes(msg.name)) buzzQueue.push(msg.name);
 renderBuzzQueue();
 stopReading(); // pause reading when someone buzzes
 // If this is the first buzz and it's our own name, show answer box
 if (buzzQueue[0] === playerName) promptAnswer();
 break;

 case 'answer':
 players[msg.name] = players[msg.name] || { pts: 0 };
 players[msg.name].pts = Math.max(0, players[msg.name].pts + (msg.correct? 10 : -5));
 renderOnlineScoreboard();
 if (msg.correct) {
 toast(`✓ ${msg.name}: "${msg.answer}"`);
 isBuzzed = true; isRevealed = true; setStatus('done'); renderWords(words.length);
 } else {
 toast(`✗ ${msg.name}: "${msg.answer}"`);
 // Remove wrong answerer from queue, give next person a chance
 buzzQueue = buzzQueue.filter(n => n !== msg.name);
 renderBuzzQueue();
 if (buzzQueue[0] === playerName) promptAnswer();
 }
 break;

 case 'reveal':
 isRevealed = true; setStatus('done'); renderWords(words.length);
 showResult(null, msg.answer, null);
 break;

 case 'chat':
 appendChat(msg.name, msg.text);
 break;
 }
}

function promptAnswer() {
 setStatus('buzzed');
 showAnswerPanel();
 document.getElementById('answerInput').placeholder = 'Your answer...';
 document.getElementById('answerInput').focus();
}

function renderBuzzQueue() {
 const bar = document.getElementById('buzzQueueBar');
 if (!buzzQueue.length) { bar.style.display='none'; return; }
 bar.style.display = 'flex';
 bar.innerHTML = buzzQueue.map((name,i) =>
 `<span class="bq-chip${i===0?' bq-answering':''}">${i===0?'⚡ ':''}${name}${name===playerName?' (you)':''}</span>`
 ).join('');
}

function renderOnlineScoreboard() {
 const sb = document.getElementById('onlineScoreboard');
 if (!roomCode) { sb.style.display='none'; return; }
 sb.style.display = 'block';
