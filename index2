// ═══════════════════════════════════════════════════
// BONUS MODE — clean rewrite
// ═══════════════════════════════════════════════════

let _bIdx = 0;          // current position in _bList
let _bList = [];        // shuffled/filtered indices into ALL_BONUSES
let _bCats = new Set(); // active category filters (empty = all)
let _bAnswered = 0;     // total parts answered this session
let _bStreak = 0;       // consecutive correct streak

// Build filtered+shuffled index list
function bBuild() {
  if (_bCats.size === 0) {
    _bList = ALL_BONUSES.map((_, i) => i);
  } else {
    _bList = ALL_BONUSES.reduce((acc, b, i) => {
      if (_bCats.has(bCat(b))) acc.push(i);
      return acc;
    }, []);
  }
  // Fisher-Yates shuffle
  for (let i = _bList.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [_bList[i], _bList[j]] = [_bList[j], _bList[i]];
  }
}

// Get category for a bonus object
function bCat(b) {
  const txt = (b.leadin || '') + ' ' + b.parts.map(p => p.question + ' ' + p.answer).join(' ');
  return classifyQuestion(txt, '');
}

// Toggle category filter pill
function toggleBonusCat(cat) {
  if (cat === 'all') {
    _bCats.clear();
  } else {
    _bCats.has(cat) ? _bCats.delete(cat) : _bCats.add(cat);
  }
  // Sync pill states
  document.querySelectorAll('#bonusCatPills .cat-pill').forEach(btn => {
    const c = btn.dataset.cat;
    btn.classList.toggle('active', c === 'all' ? _bCats.size === 0 : _bCats.has(c));
  });
  bBuild();
  _bIdx = 0;
  bLoad();
}

// Load and render the current bonus
function bLoad() {
  if (_bList.length === 0) {
    bBuild();
    _bIdx = Math.floor(Math.random() * Math.max(1, _bList.length));
  }
  if (_bList.length === 0) return;

  _bIdx = ((_bIdx % _bList.length) + _bList.length) % _bList.length;
  const bonus = ALL_BONUSES[_bList[_bIdx]];
  if (!bonus) return;

  // Header
  const pktEl = document.getElementById('bonusPacketLabel');
  const badgeEl = document.getElementById('bonusCatBadge');
  if (pktEl) pktEl.textContent = bonus.packet || '';
  if (badgeEl) {
    const cat = bCat(bonus);
    badgeEl.className = 'cat-badge ' + (CAT_BADGE_CLASS[cat] || 'cat-badge-hist');
    badgeEl.textContent = CAT_LABELS[cat] || cat;
  }

  // Leadin
  const leadinEl = document.getElementById('bonusLeadin');
  if (leadinEl) leadinEl.textContent = bonus.leadin || '';

  // Parts
  const partsEl = document.getElementById('bonusParts');
  if (!partsEl) return;
  partsEl.innerHTML = (bonus.parts || []).map((part, i) => `
    <div class="bonus-part" id="bpart-${i}">
      <div class="bonus-part-header">
        <span class="bonus-part-letter">${String.fromCharCode(65 + i)}</span>
        <span class="bonus-part-q">${escapeHtml(part.question || '')}</span>
      </div>
      <div class="bonus-part-body">
        <div class="bonus-answer-input-row">
          <input class="bonus-answer-input" id="binp-${i}"
            placeholder="Your answer…" autocomplete="off" autocorrect="off" spellcheck="false"
            onkeydown="if(event.key==='Enter'){event.preventDefault();bCheck(${i});}">
          <button class="bonus-check-btn" id="bbtn-${i}" onclick="bCheck(${i})">Check</button>
        </div>
        <div class="bonus-result" id="bres-${i}"></div>
      </div>
    </div>
  `).join('');

  // Focus first input
  setTimeout(() => { const el = document.getElementById('binp-0'); if (el) el.focus(); }, 60);
}

// Check one part answer
function bCheck(i) {
  const bonus = ALL_BONUSES[_bList[_bIdx]];
  if (!bonus || !bonus.parts[i]) return;
  const inp = document.getElementById('binp-' + i);
  const btn = document.getElementById('bbtn-' + i);
  const res = document.getElementById('bres-' + i);
  if (!inp || !btn || btn.disabled) return;

  const user = inp.value.trim().toLowerCase();
  const correct = bFuzzy(user, bonus.parts[i].answer);

  inp.disabled = true;
  btn.disabled = true;
  btn.textContent = correct ? '✓' : '✗';
  res.className = 'bonus-result ' + (correct ? 'correct' : 'wrong');
  res.textContent = correct ? '✓ Correct!' : '✗ ' + bonus.parts[i].answer;

  _bAnswered++;
  if (correct) _bStreak++;
  else _bStreak = 0;

  bUpdateScore();

  // Advance focus
  const next = document.getElementById('binp-' + (i + 1));
  if (next && !next.disabled) {
    setTimeout(() => next.focus(), 80);
  } else {
    // All parts done — blur so arrow keys work
    setTimeout(() => { if (document.activeElement) document.activeElement.blur(); }, 80);
  }
}

// Fuzzy answer matching
function bFuzzy(user, correct) {
  const norm = s => s.toLowerCase().replace(/[^a-z0-9 ]/g, '').replace(/\s+/g, ' ').trim();
  const u = norm(user);
  const c = norm(correct);
  if (!u) return false;
  if (u === c) return true;
  if (c.includes(u) && u.length >= 4) return true;
  if (u.split(' ').length >= 2 && c.startsWith(u)) return true;
  const cw = c.split(' ');
  const uw = u.split(' ');
  if (uw[0] && uw[0].length >= 5 && cw[0] === uw[0]) return true;
  return false;
}

// Update score display
