function escapeHtml(str) {
 return String(str)
.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
.replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

function escapeRegex(str) {
 return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

// ═══════════════════════════════════════════════
// Buzz Sound (Web Audio API — funny descending honk)
// ═══════════════════════════════════════════════
function playBuzzSound() {
 try {
 const ctx = new (window.AudioContext || window.webkitAudioContext)();
 const t = ctx.currentTime;

 // Sharp, short buzzer press — like a physical quiz bowl button
 // Noise burst through tight bandpass = "bzzt" click
 const bufSize = Math.ceil(ctx.sampleRate * 0.05);
 const buf = ctx.createBuffer(1, bufSize, ctx.sampleRate);
 const data = buf.getChannelData(0);
 for (let i = 0; i < bufSize; i++) data[i] = (Math.random() * 2 - 1);
 const src = ctx.createBufferSource();
 src.buffer = buf;
 const bp1 = ctx.createBiquadFilter();
 bp1.type = 'bandpass'; bp1.frequency.value = 900; bp1.Q.value = 4;
 const bp2 = ctx.createBiquadFilter();
 bp2.type = 'bandpass'; bp2.frequency.value = 1800; bp2.Q.value = 2;
 const g = ctx.createGain();
 g.gain.setValueAtTime(0.28, t);
 g.gain.exponentialRampToValueAtTime(0.001, t + 0.05);
 src.connect(bp1); bp1.connect(bp2); bp2.connect(g); g.connect(ctx.destination);
 src.start(t);

 // Tiny sub-click for physical body feel
 const sub = ctx.createOscillator();
 sub.type = 'sine';
 sub.frequency.setValueAtTime(80, t);
 sub.frequency.exponentialRampToValueAtTime(35, t + 0.06);
 const sg = ctx.createGain();
 sg.gain.setValueAtTime(0.10, t);
 sg.gain.exponentialRampToValueAtTime(0.001, t + 0.06);
 sub.connect(sg); sg.connect(ctx.destination);
 sub.start(t); sub.stop(t + 0.07);

 setTimeout(() => { try { ctx.close(); } catch(e){} }, 200);
 } catch(e) {}
}

