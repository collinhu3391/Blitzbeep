// Build a flat index of all questions for searching
let _searchIndex = null;

function buildSearchIndex() {
 if (_searchIndex && _searchIndex.length > 0) return _searchIndex;
 _searchIndex = [];
 // Tossup questions
 ALL_PACKETS.forEach((pkt, pi) => {
 pkt.questions.forEach((q, qi) => {
 _searchIndex.push({
 type: 'tossup',
 packetIdx: pi, questionIdx: qi,
 packet: pkt.packet,
 question: q.question, answer: q.answer,
 powerIdx: q.powerIdx?? null,
 _ql: q.question.toLowerCase(),
 _al: q.answer.toLowerCase(),
 });
 });
 });
 // Bonus parts — each part is a separate searchable entry
 ALL_BONUSES.forEach((b, bi) => {
 b.parts.forEach((p, pi) => {
 _searchIndex.push({
 type: 'bonus',
 bonusIdx: bi, partIdx: pi,
 packet: b.packet,
 leadin: b.leadin,
 question: p.question, answer: p.answer,
 powerIdx: null,
 _ql: (b.leadin + ' ' + p.question).toLowerCase(),
