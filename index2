function classifyQuestion(question, answer) {
 const text = (question + ' ' + (answer || '')).toLowerCase();
 if (text.includes('pencil and paper')) return 'computation';

 const scores = { literature:0, art_music:0, history:0, biology:0, physics:0, computation:0, current_events:0 };

 // ── Current Events ──
 for (const [kw, pts] of _SCORE_CURR) if (text.includes(kw)) scores.current_events += pts;

 // ── Literature ──
 for (const [kw, pts] of _SCORE_LIT) if (text.includes(kw)) scores.literature += pts;

 // ── Art & Music ──
 for (const [kw, pts] of _SCORE_ART) if (text.includes(kw)) scores.art_music += pts;

 // ── History ──
 for (const [kw, pts] of _SCORE_HIST) if (text.includes(kw)) scores.history += pts;

 // ── Biology ──
 for (const [kw, pts] of _SCORE_BIO) if (text.includes(kw)) scores.biology += pts;

 // ── Physics/Science ──
 for (const [kw, pts] of _SCORE_PHYS) if (text.includes(kw)) scores.physics += pts;

 // ── Computation/Math ──
 for (const [kw, pts] of _SCORE_COMP) if (text.includes(kw)) scores.computation += pts;

 if (scores.current_events >= 10) return 'current_events';

 // Default to history; only override if something genuinely scores higher
 let best = 'history', bestScore = 0;
 const order = ['current_events','computation','physics','biology','literature','art_music'];
 for (const cat of order) {
 if (scores[cat] > bestScore) { bestScore = scores[cat]; best = cat; }
 }
 if (scores.history > bestScore) best = 'history';
 return best;
}
// Pre-classify ALL questions in async chunks so the UI stays responsive
